// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MID
  HIGH
  URGENT
}

model User {
  id        String   @id @default(cuid())
  name      String
  handle    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[] @relation("TaskAssignee")
  meetingAttendances MeetingAttendee[]

  taskComments TaskComment[]
}

model TaskList {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String       @default("")
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MID)
  dueAt       DateTime?

  listId String?
  list   TaskList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  assigneeId String?
  assignee   User? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  tags TaskTag[]
  subtasks    TaskSubtask[]
  comments    TaskComment[]
  attachments TaskAttachment[]
  activities  TaskActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([dueAt])
  @@index([listId])
}

model TaskSubtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  checked   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, order])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([authorId])
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  name      String
  url       String   // file path or remote URL (simulated/local for now)
  mimeType  String   @default("")
  sizeBytes Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([taskId, isCover])
}

enum TaskActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  DUE_DATE_CHANGED
  ASSIGNEE_CHANGED
  LIST_CHANGED
  TAGS_CHANGED
  SUBTASKS_CHANGED
  COMMENTED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
}

model TaskActivity {
  id        String           @id @default(cuid())
  taskId    String
  type      TaskActivityType
  message   String           @default("")
  dataJson  String           @default("{}")
  createdAt DateTime         @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks TaskTag[]
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  startTime   DateTime
  endTime     DateTime
  meetingLink String   @default("")

  attendees MeetingAttendee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([endTime])
}

model MeetingAttendee {
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([meetingId, userId])
  @@index([userId])
}
